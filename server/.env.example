# HoBo POS - Environment template
# Copy to .env and set values:  cp server/.env.example .env
# When using server compose from project root, .env should be in project root.

# ============== PostgreSQL (required) ==============
POSTGRES_DB=hobo_pos
POSTGRES_USER=hobo
POSTGRES_PASSWORD=change_me_secure_password

# ============== Django (required) ==============
DJANGO_SECRET_KEY=your-50-char-secret-key-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ============== Environment: Standalone vs Demo ==============
# Standalone: DEMO_MODE=False (default in docker-compose.yml)
# Demo: DEMO_MODE=True (set in docker-compose.demo.yml)
# DEMO_MODE=

# ============== CORS (optional) ==============
# CORS_ALLOW_ALL=False

# ============== Marketing / integrations (optional) ==============
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
GOOGLE_SHEETS_JSON=/app/credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=Registrations

# ============== Optional ==============
MACHINE_ID=
