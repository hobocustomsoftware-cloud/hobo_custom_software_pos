# Docker Compose: copy to .env.docker in repo root and use:
#   docker compose -f compose/docker-compose.yml --env-file .env.docker up -d
# If you see "password authentication failed for user hobo", use this file so Postgres and backend match,
# and run: docker compose -f compose/docker-compose.yml down -v && docker compose -f compose/docker-compose.yml --env-file .env.docker up -d
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend
CORS_ALLOW_ALL=False
CORS_EXTRA_ORIGINS=http://frontend,http://frontend:80
VITE_API_URL=/api
VITE_BASE=/app/
# Must match what Postgres was initialized with (or remove volume so it re-inits with this)
POSTGRES_PASSWORD=hobo_secret
REDIS_PASSWORD=hobo_redis
