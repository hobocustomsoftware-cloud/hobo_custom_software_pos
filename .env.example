# Docker Production - Copy to .env and edit (or copy env.docker.example to .env.docker for Docker)
# cp .env.example .env

# Django (Security - A to K Recommendations)
DJANGO_SECRET_KEY=your-strong-secret-key-min-50-chars-use-openssl-rand-hex-32
DJANGO_DEBUG=False
# Docker: add backend,frontend and set CORS_EXTRA_ORIGINS (see env.docker.example)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# HTTPS - Production မှာ reverse proxy (Nginx) နောက်မှာ သုံးရင် true
SECURE_SSL_REDIRECT=true

# CORS - Production မှာ False. Docker e2e: set CORS_EXTRA_ORIGINS=http://frontend,http://frontend:80
CORS_ALLOW_ALL=False

# PostgreSQL (Docker - strong password သုံးပါ)
# In Docker, do NOT set DATABASE_HOST=localhost (compose sets DATABASE_HOST=postgres).
# DATABASE_URL is built from these; host must be "postgres" (service name).
POSTGRES_DB=hobo_pos
POSTGRES_USER=hobo
POSTGRES_PASSWORD=change-this-secure-password-min-16-chars

# Redis (rate limiting, cache, channels)
REDIS_URL=redis://redis:6379/0

# Vue Build - API URL (Nginx proxy သုံးပါက /api)
VITE_API_URL=/api

# Optional: License skip (dev only - production မှာ မသတ်မှတ်ပါ)
# SKIP_LICENSE=false
