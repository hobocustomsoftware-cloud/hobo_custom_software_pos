# Docker Compose – copy to repo root as .env.docker and edit.
# Use: docker compose -f compose/docker-compose.yml --env-file .env.docker up -d
# If backend fails with "password authentication failed for user hobo", run: down -v then up with this file.
POSTGRES_PASSWORD=hobo_secret
REDIS_PASSWORD=hobo_redis
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend
CORS_ALLOW_ALL=False
CORS_EXTRA_ORIGINS=http://frontend,http://frontend:80
VITE_API_URL=/api
VITE_BASE=/app/
