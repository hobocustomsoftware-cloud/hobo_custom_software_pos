# Production env for Cloud VPS.
# Copy to repo root as .env.prod and use:
#   docker compose -f compose/docker-compose.yml -f compose/docker-compose.prod.yml --env-file .env.prod up -d --build

# Required
DJANGO_SECRET_KEY=your-openssl-rand-hex-32-here
POSTGRES_PASSWORD=strong-postgres-password-here
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,localhost,127.0.0.1

# Optional (defaults shown)
POSTGRES_DB=hobo_pos
POSTGRES_USER=hobo
REDIS_PASSWORD=hobo_redis
VITE_API_URL=/api
VITE_BASE=/app/
SKIP_LICENSE=false
CORS_EXTRA_ORIGINS=https://your-domain.com,https://www.your-domain.com
